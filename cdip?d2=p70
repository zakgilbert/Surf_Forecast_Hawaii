  <script>
    /* Clock */
    window.setInterval("settime()", 1000);

    function lZ(x) {
      return (x > 9) ? x : "0" + x;
    }

    function settime() {
      var curtime = new Date();
      var curyear = curtime.getUTCFullYear();
      var curmonth = curtime.getUTCMonth();
      var curdate = curtime.getUTCDate();
      var curhour = curtime.getUTCHours();
      var curmin = curtime.getUTCMinutes();
      var cursec = curtime.getUTCSeconds();

      var newtime = new Date(curyear, curmonth, curdate, curhour, curmin,
        cursec);
      newtime.setTime(newtime.getTime());

      var time = lZ(newtime.getHours()) + ":" +
        lZ(newtime.getMinutes()) + " UTC";

      document.getElementById("date").clock.value = time;
    }
    /* End Clock */
  </script>
